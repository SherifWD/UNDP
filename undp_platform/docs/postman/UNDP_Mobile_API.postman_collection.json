{
  "info": {
    "name": "UNDP Mobile API (Flutter Only)",
    "_postman_id": "0c2d71a1-6f11-4f6f-9bf3-0ab5efcd0001",
    "description": "Mobile-only collection for the Flutter developer. This excludes dashboard/admin flows and covers authentication plus the `/mobile/*` endpoints used by the mobile app.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
