  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Request OTP",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{base_url}}/auth/request-otp",
            "description": "Request a login OTP.",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"country_code\": \"{{country_code}}\",\n  \"phone\": \"{{phone}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "response": []
        },
        {
          "name": "Verify OTP",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{base_url}}/auth/verify-otp",
            "description": "Verify OTP and receive bearer token.",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"country_code\": \"{{country_code}}\",\n  \"phone\": \"{{phone}}\",\n  \"code\": \"{{otp_code}}\",\n  \"preferred_locale\": \"en\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code < 300) {",
                  "  const json = pm.response.json();",
                  "  if (json.token) pm.collectionVariables.set('token', json.token);",
                  "  if (json.user && json.user.id) pm.collectionVariables.set('user_id', String(json.user.id));",
                  "  if (json.user && json.user.municipality && json.user.municipality.id) pm.collectionVariables.set('municipality_id', String(json.user.municipality.id));",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Get Current User",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              },
