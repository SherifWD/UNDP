          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code < 300) {",
                  "  const json = pm.response.json();",
                  "  const first = json?.data?.municipalities?.[0];",
                  "  if (first?.id) pm.collectionVariables.set('municipality_id', String(first.id));",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Request OTP (Unknown User - Expect Registration)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"country_code\": \"{{country_code}}\",\n  \"phone\": \"{{unknown_phone}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/auth/request-otp",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "auth",
                "request-otp"
              ]
            },
            "description": "Expected response: 404 with `requires_registration: true` when phone number is not registered."
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (pm.response.code === 404 && json?.requires_registration === true) {",
                  "  pm.collectionVariables.set(\"requires_registration\", \"true\");",
                  "}"
                ]
              }
            }
          ]
        },
